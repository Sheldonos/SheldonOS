# SheldonOS — Environment Variables
# Copy this file to .env and fill in all required values.
# Variables marked [REQUIRED] must be set before starting SheldonOS.
# Variables marked [OPTIONAL] have sensible defaults.

# ─── Infrastructure ───────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL password
POSTGRES_PASSWORD=change_me_strong_password

# [OPTIONAL] PostgreSQL username (default: sheldon)
POSTGRES_USER=sheldon

# [REQUIRED] Redis password
REDIS_PASSWORD=change_me_redis_password

# [REQUIRED] Neo4j password (for Cognee knowledge graph)
NEO4J_PASSWORD=change_me_neo4j_password

# [REQUIRED] Paperclip secret key (generate with: openssl rand -hex 32)
PAPERCLIP_SECRET_KEY=change_me_paperclip_secret

# ─── LLM API Keys ────────────────────────────────────────────────────────────
# [REQUIRED] Anthropic API key — used by all Claude agents
ANTHROPIC_API_KEY=sk-ant-...

# [REQUIRED] Perplexity API key — used by Epsilon Scout and all research agents
PERPLEXITY_API_KEY=pplx-...

# [OPTIONAL] OpenAI API key — used by OpenViking for embeddings
OPENAI_API_KEY=sk-...

# [OPTIONAL] Manus.im API key — used for complex browser-based task delegation
MANUS_API_KEY=...

# ─── Notifications ───────────────────────────────────────────────────────────
# [OPTIONAL] Telegram bot token for operator notifications
TELEGRAM_BOT_TOKEN=...

# [OPTIONAL] Telegram chat ID for operator notifications
TELEGRAM_CHAT_ID=...

# [OPTIONAL] Slack webhook URL for operator notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Financial Configuration ─────────────────────────────────────────────────
# [REQUIRED] Crypto wallet private key for Automaton trade execution
# WARNING: This wallet will be used for autonomous trading. Fund it appropriately.
# NEVER commit this value to version control.
CRYPTO_WALLET_PRIVATE_KEY=0x...

# [REQUIRED] Maximum position size per trade signal (USD)
# Start conservative — $100 is recommended for initial testing
MAX_POSITION_SIZE_USD=100

# [REQUIRED] Daily loss limit — Automaton will halt trading if this is breached (USD)
DAILY_LOSS_LIMIT_USD=500

# ─── Behavior Tuning ─────────────────────────────────────────────────────────
# [OPTIONAL] How often Epsilon Scout runs its seek cycle (seconds, default: 1800 = 30 min)
SEEK_INTERVAL_SECONDS=1800

# [OPTIONAL] Minimum opportunity score to approve for execution (0-100, default: 65)
OPPORTUNITY_SCORE_THRESHOLD=65.0

# [OPTIONAL] Minimum simulation confidence to execute a trade (%, default: 90)
MIN_TRADE_CONFIDENCE_PCT=90.0

# [OPTIONAL] Minimum expected value to execute a trade (%, default: 15)
MIN_TRADE_EV_PCT=15.0

# ─── Model Configuration ─────────────────────────────────────────────────────
# [OPTIONAL] Default model for standard agents
DEFAULT_AGENT_MODEL=claude-3-5-sonnet-20241022

# [OPTIONAL] Model for high-stakes decisions (Quant Analyst, Lead Pentester)
PREMIUM_AGENT_MODEL=claude-3-opus-20240229

# [OPTIONAL] Model for high-frequency, low-cost tasks (Market Monitor)
ECONOMY_AGENT_MODEL=claude-3-5-haiku-20241022

# [OPTIONAL] OpenViking embedding model
OPENVIKING_EMBEDDING_MODEL=text-embedding-3-small

# ─── Service URLs (override if running services externally) ──────────────────
# [OPTIONAL] Override if running Paperclip externally
PAPERCLIP_URL=http://localhost:3100

# [OPTIONAL] Override if running OpenClaw externally
OPENCLAW_URL=http://localhost:3101

# [OPTIONAL] Override if running Cognee externally
COGNEE_API_URL=http://localhost:8765

# [OPTIONAL] Override if running OpenViking externally
OPENVIKING_API_URL=http://localhost:8766

# [OPTIONAL] Override if running Percepta externally
PERCEPTA_API_URL=http://localhost:8767

# [OPTIONAL] Override if running MiroFish externally
MIROFISH_API_URL=http://localhost:8768

# [OPTIONAL] Override if running PentAGI externally
PENTAGI_API_URL=http://localhost:8769

# ─── Local Memory Fallback ────────────────────────────────────────────────────
# [OPTIONAL] Local filesystem path for OpenViking fallback when API is unavailable
OPENVIKING_LOCAL_PATH=/tmp/sheldon_memory
