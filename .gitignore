# SheldonOS — .gitignore

# Environment variables — NEVER commit
.env
*.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/
*.log.*

# Data
data/
*.db
*.sqlite3

# Docker
.docker/

# Memory / temp
/tmp/

# Secrets — NEVER commit private keys
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*.private

# Node
node_modules/
.npm/

# OS
.DS_Store
Thumbs.db
