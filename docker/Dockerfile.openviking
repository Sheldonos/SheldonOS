FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir fastapi uvicorn httpx pydantic python-dotenv asyncpg openai sentence-transformers numpy

COPY core/cognitive/openviking/ ./core/cognitive/openviking/

EXPOSE 8766

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8766/health || exit 1

CMD ["uvicorn", "core.cognitive.openviking.server:app", "--host", "0.0.0.0", "--port", "8766", "--log-level", "info"]
