FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn httpx pydantic python-dotenv

# Copy OpenClaw gateway
COPY core/control_plane/openclaw/ ./core/control_plane/openclaw/

EXPOSE 3101

CMD ["uvicorn", "core.control_plane.openclaw.gateway:app", "--host", "0.0.0.0", "--port", "3101", "--log-level", "info"]
